{
  "schemaVersion": 1,
  "id": "focus_dino",
  "name": "Focus Dino",
  "author": "Focus Pet",
  "style": "minimal_2d",
  "license": "original",
  "distribution": "redistributable",
  "defaultSize": {
    "width": 160,
    "height": 160
  },
  "anchor": {
    "x": 0.5,
    "y": 1.0
  },
  "animations": {
    "idle": {
      "folder": "idle",
      "fps": 1,
      "loop": true,
      "frameCount": 1
    },
    "blink": {
      "folder": "blink",
      "fps": 8,
      "loop": false,
      "frameCount": 1
    },
    "sleep": {
      "folder": "sleep",
      "fps": 4,
      "loop": true,
      "frameCount": 1
    },
    "focusStart": {
      "folder": "focusStart",
      "fps": 8,
      "loop": false,
      "frameCount": 1
    },
    "focusStable": {
      "folder": "focusStable",
      "fps": 6,
      "loop": true,
      "frameCount": 1
    },
    "distractedLook": {
      "folder": "distractedLook",
      "fps": 6,
      "loop": true,
      "frameCount": 1
    },
    "nudgeGentle": {
      "folder": "nudgeGentle",
      "fps": 8,
      "loop": false,
      "frameCount": 1
    },
    "breakRelax": {
      "folder": "breakRelax",
      "fps": 6,
      "loop": true,
      "frameCount": 1
    },
    "welcomeBack": {
      "folder": "welcomeBack",
      "fps": 8,
      "loop": false,
      "frameCount": 1
    },
    "stretch": {
      "folder": "stretch",
      "fps": 8,
      "loop": false,
      "frameCount": 1
    }
  }
}
